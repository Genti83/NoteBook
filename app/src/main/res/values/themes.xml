<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema kryesore - pa ActionBar, full-screen WebView -->
    <style name="Theme.NoteBook" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#2563EB</item>
        <item name="colorPrimaryVariant">#1D4ED8</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#3B82F6</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:windowBackground">#09090B</item>
        <item name="android:statusBarColor">#09090B</item>
        <item name="android:navigationBarColor">#09090B</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- Dialog i errët për API Key -->
    <style name="AlertDialog_Dark" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorPrimary">#2563EB</item>
        <item name="android:background">#18181B</item>
        <item name="android:textColorPrimary">#F4F4F5</item>
        <item name="android:textColorSecondary">#A1A1AA</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.MaterialComponents.Button</item>
    </style>
</resources>
